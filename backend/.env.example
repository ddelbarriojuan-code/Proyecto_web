# =================================================================
# KRATAMEX — Variables de entorno del backend
# Copia este archivo a .env y ajusta los valores
# =================================================================

# Credenciales de usuarios por defecto
ADMIN_USER=admin
ADMIN_PASS=admin123
USER_STANDARD=user
USER_PASS=user123

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=kratamex
DB_USER=kratamex
DB_PASSWORD=kratamex_dev

# CORS — en producción cambia a tu dominio real
CORS_ORIGIN=https://localhost

# Stripe (modo test) — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# VirusTotal Threat Intelligence (SOC panel)
# Clave gratuita en: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# Email (Gmail SMTP — recuperación de contraseña)
# Activa App Password en: myaccount.google.com → Seguridad → Contraseñas de aplicación
EMAIL_FROM=tucuenta@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
