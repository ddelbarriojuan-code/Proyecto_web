# =================================================================
# KRATAMEX — Variables raíz para Docker Compose
# Copia a .env en esta carpeta y ajusta en producción
# =================================================================

# PostgreSQL (usadas por el servicio postgres y pasadas al backend)
POSTGRES_DB=kratamex
POSTGRES_USER=kratamex
POSTGRES_PASSWORD=kratamex_dev

# Email (Gmail SMTP — recuperación de contraseña)
# Activa "App Password" en myaccount.google.com → Seguridad → Contraseñas de aplicación
EMAIL_FROM=tucuenta@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# VirusTotal Threat Intelligence (SOC panel)
# Obtén tu clave gratuita en: https://www.virustotal.com/gui/my-apikey
# Límite free tier: 4 peticiones/minuto, 500/día
# Si no se configura, el botón VT del SOC devuelve HTTP 503
VIRUSTOTAL_API_KEY=
